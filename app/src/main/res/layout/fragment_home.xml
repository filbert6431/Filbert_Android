<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Home.HomeFragment">

    <!-- TODO: Update blank fragment layout -->

    <View
        android:id="@+id/background_header"
        android:layout_width="409dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_half_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="ini adalah fragment home"
        android:textSize="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/background_header" />

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:padding="16dp"
        app:columnCount="2"
        app:layout_constraintTop_toBottomOf="@+id/background_header"
        app:useDefaultMargins="true"
        tools:layout_editor_absoluteX="-44dp">


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan2"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan7"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan3"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan4"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPertemuan5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan5"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btntoNinth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan 9"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTenth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pertemuan 10"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnlogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="logout"
            app:layout_columnWeight="1"
            app:cornerRadius="2dp"
            app:layout_gravity="fill_horizontal"/>



    </androidx.gridlayout.widget.GridLayout>




</androidx.constraintlayout.widget.ConstraintLayout>